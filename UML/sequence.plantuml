@startuml
title Student Tracker - Séquence d'authentification
skinparam sequenceMessageAlign center
skinparam maxMessageSize 150
autonumber

actor "Utilisateur" as User
boundary "AuthForm.tsx" as UI
control "AuthContext.tsx" as Context
database "Supabase Auth" as Auth
database "profiles" as Profiles
database "group_students" as GroupStudents

User -> UI : Saisit email et mot de passe\npuis clique sur « Se connecter »
activate UI

UI -> Context : signIn(email, password)
activate Context

alt Supabase configuré
    Context -> Auth : supabase.auth.signInWithPassword(...)
    activate Auth
    Auth --> Context : session + user
    deactivate Auth

    note right of Context : Chargement du rôle\net du groupe de l'utilisateur
    Context -> Profiles : select role, name by user_id
    activate Profiles
    Profiles --> Context : role
    deactivate Profiles

    Context -> GroupStudents : select group_id, groups(...) by student_id
    activate GroupStudents
    GroupStudents --> Context : groupId + groupName
    deactivate GroupStudents

    Context -> Context : setUser({...session.user, role, groupId, groupName})
else Mode démo
    Context -> Context : lit le compte demo depuis localStorage
    Context -> Context : setUser(fakeUser)
end

Context --> UI : { error: null }
deactivate Context

alt role == 'student'
    UI -> User : Redirection vers le dashboard étudiant
else role == 'teacher'
    UI -> User : Redirection vers le dashboard enseignant
end

deactivate UI
@enduml
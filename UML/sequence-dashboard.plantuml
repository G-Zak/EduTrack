@startuml
title Student Tracker - Consultation du tableau de bord
skinparam sequenceMessageAlign center
skinparam maxMessageSize 150
autonumber

actor "Utilisateur" as User
boundary "Dashboard.tsx" as Dashboard
control "AuthContext.tsx" as Auth
control "ProgressContext.tsx" as Progress
collections "Données métier\n(grades, absences, tasks, feedbacks, modules, subjects)" as Data
participant "RadialProgress" as Radial

User -> Dashboard : Ouvre la page d'accueil protégée
activate Dashboard

Dashboard -> Auth : useAuth()
activate Auth
Auth --> Dashboard : user + role + groupName
deactivate Auth

alt Rôle enseignant
  Dashboard -> Data : lit groupes, notes et tâches assignées
  Data --> Dashboard : stats enseignant
  Dashboard -> Dashboard : calcule KPI\n(groupes, étudiants, travaux à corriger)
  Dashboard --> User : Affiche les cartes de suivi enseignant
else Rôle étudiant
  Dashboard -> Progress : useProgress()
  activate Progress
  Progress --> Dashboard : lessons complétées + lastSeen
  deactivate Progress

  Dashboard -> Data : lit subjects, grades, absences, tasks, feedbacks, modules
  Data --> Dashboard : données de progression

  Dashboard -> Dashboard : calcule moyenne, absences, tâches, progression globale
  Dashboard -> Radial : value = globalPct
  Radial --> Dashboard : rendu radial de progression
  Dashboard --> User : Affiche KPI, matières, avis et progression
end

deactivate Dashboard
@enduml
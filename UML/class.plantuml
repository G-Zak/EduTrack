@startuml
skinparam classAttributeIconSize 0
left to right direction

' ==========================================
' 1. CLASSE DE BASE COMMUNE
' ==========================================
abstract class Utilisateur {
  # id: UUID
  # nom: String
  # email: String
  # institution: String
  # role: UserRole
  # dateCreation: Date
  + modifierProfil()
}

' ==========================================
' 2. CLASSES CONCRÈTES (DANS L'ORDRE REQUIS)
' ==========================================

' --- ACTEUR 1 : ÉTUDIANT ---
class Etudiant {
  - annee: String
  - filiere: String
  + consulterDashboard()
  + consulterNotes()
  + consulterAbsences()
  + consulterModules()
}

' --- ACTEUR 2 : PROFESSEUR ---
class Professeur {
  - specialite: String
  + saisirNote(etudiant: Etudiant, module: Module, note: Float)
  + validerAbsence(absence: Absence)
  + assignerDevoir(groupe: Groupe, tache: Tache)
}

' --- ACTEUR 3 : ADMINISTRATEUR ---
class Administrateur {
  + superviserModules()
  + superviserEtudiants()
  + superviserProfesseurs()
  + gererGroupes()
}

' --- CLASSES MÉTIERS GENERALES ---
class Groupe {
  - id: UUID
  - nom: String
  - description: String
  + ajouterMembre()
  + retirerMembre()
}

class Module {
  - id: UUID
  - nom: String
  - couleur: String
  - type: String
  - coefficient: Integer
  - isActive: Boolean
}

class Tache {
  - id: UUID
  - titre: String
  - description: String
  - type: String
  - dateEcheance: Date
  - priorite: String
  - statut: String
  - heuresEstimees: Float
  - heuresReelles: Float
  - creePar: String
  + mettreAJourStatut()
}

class SousTache {
  - id: UUID
  - titre: String
  - statut: String
  - heuresEstimees: Float
  - dateEcheance: Date
  + cocher()
}

class Note {
  - id: UUID
  - valeur: Float
  - coefficient: Float
  - date: Date
  - typeEvaluation: String
}

class Absence {
  - id: UUID
  - date: Date
  - duree: String
  - raison: String
  - excusee: Boolean
  - justificatifFourni: Boolean
  + fournirJustificatif()
}

class SessionEtude {
  - id: UUID
  - dateDebut: DateTime
  - dateFin: DateTime
  - dureeMinutes: Integer
  - qualiteFocus: Integer
  + demarrerChrono()
  + arreterChrono()
}

class BilanReflexion {
  - id: UUID
  - date: Date
  - heuresEtudiees: Float
  - concentration: Integer
  - satisfaction: Integer
  - motivation: Integer
  + enregistrerBilan()
}

' ==========================================
' 3. RELATIONS D'HÉRITAGE (ORDONNÉES)
' ==========================================
Utilisateur <|-- Etudiant
Utilisateur <|-- Professeur
Utilisateur <|-- Administrateur

' ==========================================
' 4. ASSOCIATIONS ET LIAISONS (ORDONNÉES)
' ==========================================

' --- LIAISONS ÉTUDIANT ---
Etudiant "1" -- "0..*" Note : possède >
Etudiant "1" -- "0..*" Absence : cumule >
Etudiant "1" -- "0..*" Tache : effectue >
Etudiant "1" -- "0..*" SessionEtude : réalise >
Etudiant "1" -- "0..*" BilanReflexion : soumet >
Etudiant "1" -- "0..*" Module : suit >
Groupe "0..*" o-- "0..*" Etudiant : contient

' --- LIAISONS PROFESSEUR ---
Groupe "0..*" o-- "0..*" Professeur : enseigné par

' --- LIAISONS ADMINISTRATEUR ---
Groupe "0..*" o-- "0..*" Administrateur : supervisé par

' --- LIAISONS DES ENTITÉS MÉTIERS ---
Tache "1" *-- "0..*" SousTache : est divisée en >
Module "1" -- "0..*" Note : concerne >
Module "1" -- "0..*" Absence : concerne >
Module "1" -- "0..*" SessionEtude : est lié à >
Module "1" -- "0..*" BilanReflexion : est lié à >
Tache "0..1" -- "0..*" SessionEtude : fait avancer >
Groupe "0..1" -- "0..*" Tache : assigné à <
Groupe "0..1" -- "0..*" Note : attribué dans <
Groupe "0..1" -- "0..*" Absence : relevé dans <

@endum

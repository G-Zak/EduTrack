@startuml
left to right direction
skinparam packageStyle rectangle

' ==========================================
' 1. DÉCLARATION DES ACTEURS (DANS L'ORDRE)
' ==========================================
actor "Étudiant" as student
actor "Professeur" as prof
actor "Administrateur" as admin


' ==========================================
' 2. SYSTÈME & CAS D'UTILISATION (ORDONNÉS)
' ==========================================
rectangle "Student Tracker" {

  ' --- CAS ÉTUDIANT ---
  usecase "S'inscrire (Choix du groupe)" as UC_Register
  usecase "Consulter le tableau de bord (Dashboard)" as UC_ConsultDashboard
  usecase "Consulter ses notes" as UC_ConsultGrades
  usecase "Consulter ses modules" as UC_ConsultModules
  usecase "Consulter ses tâches & sous-tâches" as UC_ManagePersonalTasks
  usecase "Consulter ses absences" as UC_ConsultAbsences
  

  ' --- CAS PROFESSEUR ---
  usecase "Créer les tâches" as UC_CreateTasks
  usecase "Assigner des tâches/devoirs au groupe" as UC_AssignTasks
  usecase "Saisir & Gérer les notes" as UC_AddGrades
  usecase "Saisir & Valider les absences" as UC_ManageAbsences
  usecase "Consulter les statistiques du groupe" as UC_ViewClassStats
  
  ' --- CAS ADMINISTRATEUR ---
  usecase "Superviser les modules (matières)" as UC_SuperviseModules
  usecase "Superviser les étudiants" as UC_SuperviseStudents
  usecase "Superviser les professeurs" as UC_SuperviseTeachers
  usecase "Gérer les classes / groupes" as UC_ManageGroups
}

' ==========================================
' 3. LIAISONS ACTEURS -> CAS (ORDONNÉES)
' ==========================================

' --- LIAISONS ÉTUDIANT ---
student --> UC_Register
student --> UC_ConsultDashboard
student --> UC_ConsultGrades
student --> UC_ConsultModules
student --> UC_ManagePersonalTasks
student --> UC_ConsultAbsences


' --- LIAISONS PROFESSEUR ---
prof --> UC_CreateTasks
prof --> UC_AssignTasks
prof --> UC_AddGrades
prof --> UC_ManageAbsences
prof --> UC_ViewClassStats

' --- LIAISONS ADMINISTRATEUR ---
admin --> UC_SuperviseModules
admin --> UC_SuperviseStudents
admin --> UC_SuperviseTeachers
admin --> UC_ManageGroups

' ==========================================
' 4. DÉPENDANCES ET INCLUSIONS
' ==========================================
UC_AssignTasks ..> UC_ManagePersonalTasks : <<include>>
UC_AddGrades ..> UC_ConsultGrades : <<include>>
UC_ManageAbsences ..> UC_ConsultAbsences : <<include>>

@endum

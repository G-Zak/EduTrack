@startuml
title Student Tracker - Création d'une tâche
skinparam sequenceMessageAlign center
skinparam maxMessageSize 150
autonumber

actor "Utilisateur" as User
boundary "TasksPage.tsx" as Page
boundary "TaskCreationForm.tsx" as Form
control "AuthContext.tsx" as Auth
database "Supabase / localStorage" as Store

User -> Page : Ouvre la page des tâches
activate Page

Page -> Auth : useAuth()
activate Auth
Auth --> Page : user + isConfigured + groupId
deactivate Auth

alt Mode professeur
  Page -> Store : charge les groupes puis les tâches du groupe sélectionné
  Store --> Page : liste des tâches du groupe

  User -> Page : Clique sur « + Assigner Devoir »
  Page -> Form : Affiche le formulaire de création
  activate Form

  User -> Form : Renseigne titre, description, date et priorité
  Form -> Form : validateForm()
  Form --> Page : onTaskCreated(task)
  deactivate Form

  Page -> Store : crée les tâches pour les étudiants du groupe
  Store --> Page : insertion terminée
  Page -> Page : setTasks(...)
  Page -> User : Ferme le formulaire et actualise la liste
else Mode étudiant
  Page -> Store : charge les tâches perso et de groupe
  Store --> Page : liste des tâches

  User -> Page : Clique sur « Créer une tâche »
  Page -> Form : Affiche le formulaire
  activate Form

  User -> Form : Renseigne les champs puis valide
  Form -> Form : validateForm()
  Form --> Page : onTaskCreated(task)
  deactivate Form

  Page -> Store : insert / saveStudentTasks()
  Store --> Page : tâche enregistrée
  Page -> Page : setTasks(...)
  Page -> User : Ferme le formulaire et rafraîchit l'affichage
end

deactivate Page
@enduml